---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio');
  return portfolioEntries.map(entry => ({
    params: { slug: entry.id || entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { layout_template = 'bento' } = entry.data;
const gallery = entry.data.gallery || [];
const allImages = [entry.data.image, ...gallery].filter(Boolean);
---
<Layout title={`${entry.data.title} | Portfolio`}>
  <section class="pt-32 pb-24 px-4 sm:px-6 max-w-7xl mx-auto min-h-screen">

    <!-- Back Link -->
    <div class="mb-8 reveal">
      <a href="/works" class="text-sm font-semibold text-[#00C4CC] uppercase tracking-wider hover:underline inline-flex items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i>Back to Works
      </a>
    </div>

    {layout_template === 'bento' ? (
      <!-- ========== BENTO LAYOUT ========== -->
      <div class="bento-wrapper reveal">
        <!-- LEFT: Info Panel (sticky) -->
        <div class="bento-info-panel">
          <div class="bento-label">
            <span class="text-xs font-bold tracking-widest uppercase text-[#00C4CC]">Portfolio</span>
            <span class="mx-2 text-[#00C4CC] opacity-40">·</span>
            <span class="text-xs font-bold tracking-widest uppercase" style="color: var(--text-muted)">{entry.data.category}</span>
          </div>

          <h1 class="bento-title">{entry.data.title}</h1>

          <p class="bento-desc">{entry.data.description}</p>

          <div class="bento-meta">
            <div class="bento-meta-item">
              <i class="fa-solid fa-tag text-[#00C4CC]"></i>
              <div>
                <p class="bento-meta-label">Category</p>
                <p class="bento-meta-value">{entry.data.category}</p>
              </div>
            </div>
            <div class="bento-meta-item">
              <i class="fa-solid fa-images text-[#00C4CC]"></i>
              <div>
                <p class="bento-meta-label">Gallery</p>
                <p class="bento-meta-value">{allImages.length} Images</p>
              </div>
            </div>
          </div>

          {entry.data.canva_link && entry.data.canva_link !== '#' && (
            <a href={entry.data.canva_link} target="_blank" rel="noopener noreferrer" class="btn-accent w-full text-center text-white font-bold px-6 py-4 rounded-full text-sm flex items-center justify-center gap-2 mt-6">
              OPEN IN CANVA
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          )}

          {/* Date label */}
          <p class="bento-date">Design Project</p>
        </div>

        <!-- RIGHT: Bento Mosaic Gallery Grid -->
        <div class="bento-grid">
          {allImages.length === 0 && (
            <div class="bento-cell bento-cell-main">
              <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover" />
            </div>
          )}
          {allImages.length >= 1 && (
            <div class="bento-cell bento-cell-main">
              <img src={allImages[0]} alt={`${entry.data.title} 1`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="eager" />
            </div>
          )}
          {allImages.length >= 2 && (
            <div class="bento-cell bento-cell-sm">
              <img src={allImages[1]} alt={`${entry.data.title} 2`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          )}
          {allImages.length >= 3 && (
            <div class="bento-cell bento-cell-sm">
              <img src={allImages[2]} alt={`${entry.data.title} 3`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          )}
          {allImages.length >= 4 && (
            <div class="bento-cell bento-cell-wide">
              <img src={allImages[3]} alt={`${entry.data.title} 4`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          )}
          {allImages.length >= 5 && (
            <div class="bento-cell bento-cell-sm">
              <img src={allImages[4]} alt={`${entry.data.title} 5`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          )}
          {allImages.length >= 6 && (
            <div class="bento-cell bento-cell-sm bento-cell-accent">
              <img src={allImages[5]} alt={`${entry.data.title} 6`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          )}
          {allImages.length > 6 && allImages.slice(6).map((img: string, i: number) => (
            <div class="bento-cell bento-cell-sm">
              <img src={img} alt={`${entry.data.title} ${i + 7}`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- Content Area -->
      {Content && (
        <div class="bento-content-area reveal">
          <div class="prose prose-lg dark:prose-invert max-w-3xl" style="color: var(--text-secondary)">
            <Content />
          </div>
        </div>
      )}

    ) : layout_template === 'basic' ? (
      <>
        <div class="text-center mb-12 reveal">
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4" style="color: var(--text-primary)">{entry.data.title}</h1>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary)">{entry.data.description}</p>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-2xl mb-16 reveal-scale w-full max-w-4xl mx-auto border-4" style="border-color: var(--bg-card)">
          <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto object-cover" />
        </div>
        <div class="flex flex-col md:flex-row gap-16 reveal max-w-5xl mx-auto">
          <div class="flex-1 prose prose-xl dark:prose-invert leading-relaxed" style="color: var(--text-secondary)">
            <Content />
          </div>
          <div class="w-full md:w-1/3 min-w-[280px] space-y-6">
            <div class="p-8 rounded-2xl border" style="background: var(--bg-card); border-color: var(--border-color)">
              <h3 class="text-xl font-bold mb-4" style="color: var(--text-primary)">Project Info</h3>
              <p class="text-sm" style="color: var(--text-secondary)"><strong style="color: var(--text-primary)">Category:</strong> {entry.data.category}</p>
              {entry.data.canva_link && entry.data.canva_link !== '#' && (
                <a href={entry.data.canva_link} target="_blank" rel="noopener noreferrer" class="btn-accent inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full text-sm mt-4 w-full justify-center">
                  OPEN IN CANVA <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
                </a>
              )}
            </div>
          </div>
        </div>
      </>
    ) : (
      <!-- Side by Side Layout -->
      <div class="flex flex-col lg:flex-row gap-16 reveal items-start">
        <div class="flex-1 w-full lg:sticky lg:top-32 rounded-3xl overflow-hidden shadow-2xl reveal-scale border-4" style="border-color: var(--bg-card)">
          <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto object-cover" />
        </div>
        <div class="flex-1 w-full flex flex-col gap-10">
          <h1 class="text-4xl font-extrabold" style="color: var(--text-primary)">{entry.data.title}</h1>
          <p class="text-lg" style="color: var(--text-secondary)">{entry.data.description}</p>
          <div class="prose prose-lg dark:prose-invert w-full max-w-none" style="color: var(--text-secondary)">
            <Content />
          </div>
          <div class="p-8 rounded-3xl border shadow-sm" style="background: var(--bg-card); border-color: var(--border-color)">
            <h3 class="text-xl font-bold mb-4" style="color: var(--text-primary)">Project Info</h3>
            <p class="text-sm mb-4" style="color: var(--text-secondary)"><span class="font-semibold" style="color: var(--text-muted)">Category:</span> {entry.data.category}</p>
            {entry.data.canva_link && entry.data.canva_link !== '#' && (
              <a href={entry.data.canva_link} target="_blank" rel="noopener noreferrer" class="btn-accent inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full text-sm">
                OPEN IN CANVA <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
              </a>
            )}
          </div>
        </div>
      </div>
    )}

    <!-- ========== SWIPEABLE FULL GALLERY (All layouts) ========== -->
    {allImages.length > 1 && (
      <div class="mt-24 mb-12 max-w-7xl mx-auto reveal">
        <div class="flex items-center justify-between mb-8 px-2">
          <h2 class="text-2xl font-bold" style="color: var(--text-primary)">Full Gallery</h2>
          <div class="flex gap-3">
            <button id="scroll-left" class="gallery-nav-btn" aria-label="Scroll left">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
            <button id="scroll-right" class="gallery-nav-btn" aria-label="Scroll right">
              <i class="fa-solid fa-chevron-right"></i>
            </button>
          </div>
        </div>
        <div id="gallery-container" class="gallery-strip">
          {allImages.map((img: string, index: number) => (
            <div class="gallery-strip-item">
              <img src={img} alt={`${entry.data.title} ${index + 1}`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    )}

  </section>

  <style>
    /* ===== BENTO LAYOUT ===== */
    .bento-wrapper {
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 2rem;
      align-items: start;
      margin-bottom: 2rem;
    }

    @media (max-width: 1024px) {
      .bento-wrapper {
        grid-template-columns: 1fr;
      }
    }

    .bento-info-panel {
      position: sticky;
      top: 7rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    @media (max-width: 1024px) {
      .bento-info-panel {
        position: static;
      }
    }

    .bento-label {
      display: flex;
      align-items: center;
    }

    .bento-title {
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 800;
      line-height: 1.1;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin: 0;
    }

    .bento-desc {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text-secondary);
    }

    .bento-meta {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 1.25rem;
      border-radius: 1rem;
      border: 1px solid var(--border-color);
      background: var(--bg-card);
    }

    .bento-meta-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .bento-meta-item i {
      width: 1.5rem;
      text-align: center;
    }

    .bento-meta-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin: 0;
    }

    .bento-meta-value {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
    }

    .bento-date {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    /* ===== BENTO GRID ===== */
    .bento-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 200px;
      gap: 0.75rem;
    }

    @media (max-width: 640px) {
      .bento-grid {
        grid-template-columns: repeat(2, 1fr);
        grid-auto-rows: 160px;
      }
    }

    .bento-cell {
      border-radius: 1rem;
      overflow: hidden;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      box-shadow: 0 4px 16px var(--shadow-color);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .bento-cell:hover {
      transform: scale(1.02);
      box-shadow: 0 12px 32px var(--shadow-hover);
    }

    .bento-cell img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Main large cell: spans 2 cols, 2 rows */
    .bento-cell-main {
      grid-column: span 2;
      grid-row: span 2;
    }

    /* Normal small cell */
    .bento-cell-sm {
      grid-column: span 1;
      grid-row: span 1;
    }

    /* Wide cell: 2 cols */
    .bento-cell-wide {
      grid-column: span 2;
      grid-row: span 1;
    }

    /* Accent cell with gradient overlay */
    .bento-cell-accent {
      position: relative;
    }

    .bento-cell-accent::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(0, 196, 204, 0.15), transparent);
      pointer-events: none;
      border-radius: inherit;
    }

    /* Content area below bento */
    .bento-content-area {
      padding: 3rem 0 1rem;
      border-top: 1px solid var(--border-color);
      margin-top: 2rem;
    }

    /* ===== GALLERY STRIP ===== */
    .gallery-strip {
      display: flex;
      overflow-x: auto;
      gap: 1rem;
      padding-bottom: 1rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .gallery-strip::-webkit-scrollbar {
      display: none;
    }

    .gallery-strip-item {
      flex: none;
      width: 80%;
      max-width: 480px;
      height: 340px;
      scroll-snap-align: center;
      border-radius: 1.5rem;
      overflow: hidden;
      border: 2px solid var(--border-color);
      box-shadow: 0 8px 24px var(--shadow-color);
    }

    @media (max-width: 640px) {
      .gallery-strip-item {
        width: 90%;
        height: 240px;
      }
    }

    .gallery-nav-btn {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 50%;
      border: 1px solid var(--border-color);
      background: var(--bg-card);
      color: var(--text-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.25s ease;
      font-size: 0.85rem;
    }

    .gallery-nav-btn:hover {
      background: #00C4CC;
      color: white;
      border-color: #00C4CC;
      transform: scale(1.1);
    }
  </style>

  <script>
    function initGallery() {
      const container = document.getElementById('gallery-container');
      const leftBtn = document.getElementById('scroll-left');
      const rightBtn = document.getElementById('scroll-right');

      if (container && leftBtn && rightBtn) {
        const getScrollAmount = () => {
          const card = container.firstElementChild as HTMLElement;
          return card ? card.offsetWidth + 16 : 400;
        };
        leftBtn.addEventListener('click', () => {
          container.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
        });
        rightBtn.addEventListener('click', () => {
          container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        });
      }
    }

    initGallery();
    document.addEventListener('astro:after-swap', initGallery);
  </script>
</Layout>
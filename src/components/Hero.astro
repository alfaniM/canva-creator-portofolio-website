---
import siteData from '../data/site.json';
const { personal } = siteData;
const badge = personal.badge;
---

<section id="hero" class="relative min-h-[90vh] flex items-center overflow-hidden pt-20">
  <!-- Blobs -->
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>

  <!-- Decorative shapes -->
  <div class="deco-shape deco-ring" style="width:80px;height:80px;top:15%;right:12%"></div>
  <div class="deco-shape deco-ring" style="width:50px;height:50px;bottom:20%;left:8%"></div>
  <div class="deco-cross" style="top:25%;right:25%;animation: decoFloat2 5s ease-in-out infinite"></div>
  <div class="deco-cross" style="bottom:30%;left:20%;animation: decoFloat2 7s ease-in-out infinite;animation-delay:-3s"></div>

  <div class="max-w-6xl mx-auto px-6 w-full relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

      <!-- ========= TEXT CONTENT ========= -->
      <div class="flex-1 text-center md:text-left order-2 md:order-1">
        <p class="text-[#00C4CC] font-semibold text-sm tracking-widest uppercase mb-3 reveal">Hello, I'm</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-4 reveal" style="color: var(--text-primary)">
          <span id="hero-typed-name" data-name={personal.name}></span><span class="typing-cursor"></span>
        </h1>
        <p class="text-lg sm:text-xl text-[#00C4CC] font-semibold mb-5 reveal">
          {personal.role}
        </p>
        <p class="leading-relaxed max-w-lg mx-auto md:mx-0 mb-8 reveal" style="color: var(--text-secondary)">
          {personal.bio}
        </p>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start reveal">
          <a href="/works" class="hero-btn-primary magnetic-btn">
            VIEW MY WORK
            <span class="hero-btn-arrow"><i class="fa-solid fa-arrow-right text-xs"></i></span>
          </a>
          <a href="/about" class="hero-btn-outline magnetic-btn">
            MORE ABOUT ME
          </a>
        </div>
      </div>

      <!-- ========= PHOTO SIDE ========= -->
      <div class="flex-1 flex justify-center order-1 md:order-2 reveal-scale">
        <div class="hero-photo-wrap" id="parallax-wrap">

          <!-- Large organic blob behind photo -->
          <div class="hero-bg-blob" id="parallax-deco" aria-hidden="true"></div>

          <!-- Spinning "Hire Me" ring badge -->
          <div class="hire-me-ring" id="hire-me-ring" aria-label="Open to hire" title="I'm available for new projects">
            <svg class="hire-ring-svg" viewBox="0 0 120 120">
              <path id="hire-ring-path" d="M60,10 a50,50 0 1,1 -0.001,0" fill="none"/>

              </text>
            </svg>
            <!-- Center arrow icon -->
            <div class="hire-ring-center">
              <i class="fa-solid fa-arrow-up-right"></i>
            </div>
          </div>

          <!-- Canva Creator badge (compact, bottom-left) -->
          <div class="canva-badge-circle float-badge" title={`${badge.text} ${badge.subtext}`}>
            <i class={badge.icon}></i>
            <span class="canva-badge-text">{badge.text}</span>
            <span class="canva-badge-sub">{badge.subtext}</span>
          </div>

          <!-- Floating role tags -->
          <span class="role-tag role-tag-1 float-badge" style="animation-delay: 0s">
            <i class="fa-solid fa-paintbrush mr-1.5"></i>Hire me!
          </span>
          <span class="role-tag role-tag-2 float-badge" style="animation-delay: -1.5s">
            <i class="fa-solid fa-palette mr-1.5"></i>Graphic Designer
          </span>

          <!-- Photo (parallax inner) -->
          <div id="parallax-photo" class="hero-photo-frame">
            <!-- Photo blob clipped circle -->
            <div class="hero-photo-circle" id="tilt-card">
              <img
                src={personal.photo_url}
                alt={personal.name}
                class="hero-photo-img"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <!-- Subtle ring around photo -->
            <div class="hero-photo-ring" aria-hidden="true"></div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========== PHOTO WRAP ========== */
  .hero-photo-wrap {
    position: relative;
    width: 340px;
    height: 400px;
  }

  @media (max-width: 640px) {
    .hero-photo-wrap { width: 280px; height: 320px; }
  }

  /* ========== BIG ORGANIC BLOB ========== */
  .hero-bg-blob {
    position: absolute;
    width: 300px;
    height: 300px;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, rgba(0,196,204,0.55), rgba(0,163,170,0.4));
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    animation: blobMorph 8s ease-in-out infinite;
    transition: transform 0.1s linear;
    will-change: transform;
    z-index: 1;
  }

  html.dark .hero-bg-blob {
    background: linear-gradient(135deg, rgba(0,196,204,0.35), rgba(0,163,170,0.25));
  }

  @keyframes blobMorph {
    0%, 100% { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
    33%       { border-radius: 42% 58% 75% 25% / 67% 46% 54% 33%; }
    66%       { border-radius: 75% 25% 42% 58% / 30% 60% 40% 70%; }
  }

  /* ========== PHOTO CIRCLE ========== */
  .hero-photo-frame {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    transition: transform 0.1s linear;
    will-change: transform;
  }

  .hero-photo-circle {
    width: 240px;
    height: 300px;
    border-radius: 140px 140px 0 0;
    overflow: hidden;
    position: relative;
    transition: transform 0.15s ease-out;
  }

  @media (max-width: 640px) {
    .hero-photo-circle { width: 190px; height: 240px; }
  }

  .hero-photo-circle:hover {
    transform: perspective(1000px) rotateY(4deg) rotateX(-3deg) scale(1.03);
  }

  .hero-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .hero-photo-circle:hover .hero-photo-img { transform: scale(1.06); }

  .hero-photo-ring {
    position: absolute;
    inset: -10px;
    border-radius: 150px 150px 0 0;
    border: 2px solid rgba(0,196,204,0.3);
    pointer-events: none;
    animation: ringPulse 4s ease-in-out infinite;
  }

  @keyframes ringPulse {
    0%, 100% { opacity: 0.35; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.015); }
  }

  /* ========== SPINNING HIRE ME BADGE ========== */
  .hire-me-ring {
    position: absolute;
    top: 0;
    right: -10px;
    z-index: 10;
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .hire-me-ring:hover { transform: scale(1.1); }
  .hire-me-ring:hover .hire-ring-center { background: #00C4CC; color: white; }

  .hire-ring-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    animation: spinSlow 10s linear infinite;
  }

  .hire-ring-text {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    fill: var(--text-primary);
  }

  html.dark .hire-ring-text { fill: #e2e8f0; }

  @keyframes spinSlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .hire-ring-center {
    position: relative;
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #00C4CC;
    font-size: 0.9rem;
    transition: background 0.25s, color 0.25s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }

  @media (max-width: 640px) {
    .hire-me-ring { width: 72px; height: 72px; right: -5px; top: 5px; }
    .hire-ring-svg { font-size: 12px; }
    .hire-ring-center { width: 32px; height: 32px; }
  }

  /* ========== FLOATING ROLE TAGS ========== */
  .role-tag {
    position: absolute;
    z-index: 10;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 700;
    white-space: nowrap;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  /* Light mode */
  html:not(.dark) .role-tag {
    background: rgba(255,255,255,0.88);
    border: 1px solid rgba(255,255,255,0.6);
    color: #0f172a;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }

  /* Dark mode */
  html.dark .role-tag {
    background: rgba(30,41,59,0.85);
    border: 1px solid rgba(255,255,255,0.1);
    color: #e2e8f0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.35);
  }

  .role-tag i { color: #00C4CC; }

  /* Positions */
  .role-tag-1 { bottom: 38%; left: -20px; }
  .role-tag-2 { bottom: 20%; right: -15px; background: rgba(0,196,204,0.15) !important; border-color: rgba(0,196,204,0.35) !important; color: #00C4CC !important; }
  .role-tag-3 { top: 20%; left: 5%; }

  html.dark .role-tag-2 { background: rgba(0,196,204,0.12) !important; }

  @media (max-width: 640px) {
    .role-tag-1 { left: -15px; font-size: 0.7rem; }
    .role-tag-2 { right: -10px; font-size: 0.7rem; }
    .role-tag-3 { left: 0; top: 15%; font-size: 0.7rem; }
  }

  /* ========== CANVA CREATOR BADGE ========== */
  .canva-badge-circle {
    position: absolute;
    bottom: 24px;
    left: -15px;
    z-index: 10;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    background: linear-gradient(145deg, rgba(0,196,204,0.9), rgba(0,163,170,0.85));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 2px solid rgba(255,255,255,0.35);
    box-shadow: 0 8px 32px rgba(0,196,204,0.4), 0 0 0 3px rgba(0,196,204,0.15), inset 0 1px 0 rgba(255,255,255,0.3);
    color: white;
    cursor: default;
    transition: transform 0.3s ease;
  }
  .canva-badge-circle:hover { transform: scale(1.12) rotate(-5deg) !important; }
  .canva-badge-circle i { font-size: 14px; }
  .canva-badge-text { font-size: 9px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; line-height: 1; }
  .canva-badge-sub  { font-size: 8px; font-weight: 600; opacity: 0.85; line-height: 1; }

  @media (max-width: 640px) {
    .canva-badge-circle { width: 58px; height: 58px; left: -10px; bottom: 16px; }
    .canva-badge-circle i { font-size: 11px; }
    .canva-badge-text { font-size: 7px; }
    .canva-badge-sub  { font-size: 6px; }
  }

  /* ========== BUTTONS ========== */
  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 0.85rem 0.85rem 1.75rem;
    background: linear-gradient(135deg, #00C4CC, #00A3AA);
    color: white;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    border-radius: 9999px;
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative;
    overflow: hidden;
  }
  .hero-btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .hero-btn-primary:hover::after { transform: translateX(100%); }
  .hero-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(0,196,204,0.45); }

  .hero-btn-arrow {
    width: 2rem; height: 2rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.22);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.25s;
  }
  .hero-btn-primary:hover .hero-btn-arrow { transform: translateX(3px); }

  .hero-btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.75rem;
    border: 2px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    border-radius: 9999px;
    transition: border-color 0.25s, color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .hero-btn-outline:hover {
    border-color: #00C4CC;
    color: #00C4CC;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,196,204,0.15);
  }

  /* ========== MAGNETIC BUTTON MICROINTERACTION ========== */
  .magnetic-btn { will-change: transform; }
</style>

<script>
  // ===== TYPING ANIMATION =====
  function initTyping() {
    const el = document.getElementById('hero-typed-name');
    if (!el) return;
    const name = el.dataset.name || 'Muhammad Aulia';
    el.textContent = '';
    let i = 0;
    const type = () => {
      if (i < name.length) {
        el.textContent += name[i++];
        setTimeout(type, 80);
      }
    };
    setTimeout(type, 600);
  }

  // ===== PARALLAX ON MOUSE MOVE =====
  function initParallax() {
    const photo = document.getElementById('parallax-photo');
    const blob  = document.getElementById('parallax-deco');
    if (!photo && !blob) return;

    const onMove = (e: MouseEvent) => {
      const x = (e.clientX / window.innerWidth  - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      if (photo) photo.style.transform = `translateX(-50%) translate(${x*14}px, ${y*14}px)`;
      if (blob)  blob.style.transform  = `translateX(-50%) translate(${x*24}px, ${y*24}px)`;
    };

    const onLeave = () => {
      const t = 'transform 0.6s cubic-bezier(0.16,1,0.3,1)';
      if (photo) { photo.style.transition = t; photo.style.transform = 'translateX(-50%)'; setTimeout(() => { photo.style.transition = ''; }, 600); }
      if (blob)  { blob.style.transition  = t; blob.style.transform  = 'translateX(-50%)'; setTimeout(() => { blob.style.transition  = ''; }, 600); }
    };

    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('mouseleave', onLeave);
  }

  // ===== MAGNETIC BUTTONS =====
  function initMagnetic() {
    document.querySelectorAll<HTMLElement>('.magnetic-btn').forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const r = btn.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top  - r.height / 2;
        btn.style.transform = `translate(${x * 0.22}px, ${y * 0.22}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transition = 'transform 0.4s cubic-bezier(0.16,1,0.3,1)';
        btn.style.transform = '';
        setTimeout(() => { btn.style.transition = ''; }, 400);
      });
    });
  }

  // ===== HIRE ME RING: pause spin on hover =====
  function initHireRing() {
    const svg = document.querySelector<SVGElement>('.hire-ring-svg');
    const ring = document.getElementById('hire-me-ring');
    if (!svg || !ring) return;
    ring.addEventListener('mouseenter', () => { svg.style.animationPlayState = 'paused'; });
    ring.addEventListener('mouseleave', () => { svg.style.animationPlayState = 'running'; });
  }

  function init() {
    initTyping();
    initParallax();
    initMagnetic();
    initHireRing();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>

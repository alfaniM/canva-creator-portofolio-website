---
import { getCollection } from 'astro:content';
import OptimizedImage from './OptimizedImage.astro';

const allPortfolio = await getCollection('portfolio');
const portfolioItems = allPortfolio.sort((a, b) => a.data.order - b.data.order);

interface Props {
  limit?: number;
  showFilters?: boolean;
}

const { limit, showFilters = true } = Astro.props;
const displayItems = limit ? portfolioItems.slice(0, limit) : portfolioItems;

// ── Derive categories dynamically from actual content (no site.json dependency)
// This guarantees tab names ALWAYS match the card data-category attributes.
const categorySet = new Set<string>();
displayItems.forEach(item => { if (item.data.category) categorySet.add(item.data.category); });
const categories = ['All', ...Array.from(categorySet)];
---
<section id="my-work" class="py-24 relative" style="background: var(--bg-secondary)">
  <div class="deco-shape deco-ring" style="width:100px;height:100px;top:8%;left:5%"></div>
  <div class="deco-shape deco-dot" style="width:10px;height:10px;bottom:15%;right:8%;animation-delay:-1s"></div>
  <div class="deco-cross" style="top:12%;right:8%;animation: decoFloat2 6s ease-in-out infinite"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[#00C4CC] font-semibold text-sm tracking-widest uppercase mb-2">Portfolio</p>
      <h2 class="text-3xl sm:text-4xl font-bold" style="color: var(--text-primary)">
        {limit ? 'Featured Works' : 'My Work'}
      </h2>
      <div class="w-16 h-1 bg-[#00C4CC] rounded-full mx-auto mt-4"></div>
      <p class="mt-4 max-w-md mx-auto text-sm" style="color: var(--text-muted)">
        A curated collection of design work across branding, social media, and print.
      </p>
    </div>

    <!-- Apple glassmorphism category tabs -->
    {showFilters && categories.length > 1 && (
      <div class="tabs-wrap mb-12">
        <div class="tabs-fade tabs-fade-left"></div>
        <div class="tabs-fade tabs-fade-right"></div>

        <div class="tabs-glass-bg">
          <div id="work-tabs" class="tabs-inner hide-scrollbar" role="tablist">
            <!-- Sliding active indicator (absolutely positioned inside the pill bar) -->
            <span id="tab-indicator" aria-hidden="true"></span>

            {categories.map((cat, i) => (
              <button
                class={`tab-pill ${i === 0 ? 'tab-pill-active' : ''}`}
                data-category={cat}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Portfolio grid — fixed min-height prevents layout shift on filter -->
    <div
      id="portfolio-grid"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7"
    >
      {displayItems.map((item, idx) => (
        <a
          href={`/works/${(item.id || item.slug).replace(/\.md$/, '')}`}
          class="portfolio-card group block rounded-2xl overflow-hidden"
          data-category={item.data.category}
          style={`--i:${idx}`}
        >
          <div class="card-img-wrap">
            <div class="img-shimmer"></div>
            <OptimizedImage
              src={item.data.image}
              alt={item.data.title}
              width={800}
              height={600}
              quality={82}
              loading={idx < 3 ? 'eager' : 'lazy'}
              fetchpriority={idx === 0 ? 'high' : 'auto'}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              class="card-img"
            />
            <div class="card-glass-overlay">
              <span class="card-overlay-label">View Project</span>
              <i class="fa-solid fa-arrow-up-right-from-square card-overlay-icon"></i>
            </div>
            <div class="card-cat-pill">{item.data.category}</div>
          </div>

          <div class="card-body">
            <h3 class="card-title">{item.data.title}</h3>
            <p class="card-desc">{item.data.description}</p>
            <div class="card-cta">
              <span>VIEW DETAILS</span>
              <i class="fa-solid fa-arrow-right card-cta-arrow"></i>
            </div>
          </div>
        </a>
      ))}
    </div>

    {limit && (
      <div class="mt-12 text-center reveal">
        <a href="/works" class="btn-accent inline-flex items-center gap-2 text-white font-semibold px-8 py-3.5 rounded-full text-sm">
          SEE ALL WORKS
          <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  /* ===== GLASSMORPHISM TAB BAR ===== */
  .tabs-wrap { position: relative; width: 100%; }

  .tabs-fade {
    position: absolute; top: 0; bottom: 0; width: 2.5rem;
    z-index: 2; pointer-events: none;
  }
  .tabs-fade-left  { left: 0;  background: linear-gradient(to right, var(--bg-secondary), transparent); }
  .tabs-fade-right { right: 0; background: linear-gradient(to left,  var(--bg-secondary), transparent); }
  @media (min-width: 640px) { .tabs-fade-left, .tabs-fade-right { display: none; } }

  .tabs-glass-bg { display: flex; justify-content: center; }
  @media (max-width: 639px) { .tabs-glass-bg { display: block; overflow: hidden; } }

  .tabs-inner {
    position: relative;           /* for the absolute indicator */
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.375rem;
    border-radius: 9999px;
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.65);
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,0.8);
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
  }

  html.dark .tabs-inner {
    background: rgba(15,23,42,0.65);
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04);
  }

  /* ── Animated sliding indicator ── */
  #tab-indicator {
    position: absolute;
    top: 0.375rem;
    left: 0;        /* JS will set left + width */
    height: calc(100% - 0.75rem);
    border-radius: 9999px;
    background: linear-gradient(135deg, #00C4CC, #00A3AA);
    box-shadow: 0 4px 14px rgba(0,196,204,0.45);
    z-index: 0;
    pointer-events: none;
    /* Spring-like cubic bezier — feels like iOS */
    transition: left 0.35s cubic-bezier(0.34,1.56,0.64,1), width 0.35s cubic-bezier(0.34,1.56,0.64,1);
    opacity: 0; /* hidden until JS measures */
  }

  .tab-pill {
    position: relative;
    z-index: 1;           /* above indicator */
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    border: none;
    background: transparent;
    cursor: pointer;
    transition: color 0.25s ease;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .tab-pill:hover:not(.tab-pill-active) { color: var(--text-primary); }
  .tab-pill-active { color: #fff !important; }

  /* ===== PORTFOLIO CARDS ===== */
  .portfolio-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    box-shadow: 0 2px 12px var(--shadow-color);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease, border-color 0.3s ease, opacity 0.4s ease;
    animation: popIn 0.5s cubic-bezier(0.16,1,0.3,1) backwards;
  }
  @keyframes popIn {
    0% { opacity: 0; transform: scale(0.95) translateY(10px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  .portfolio-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px var(--shadow-hover);
    border-color: rgba(0,196,204,0.25);
  }

  /* Fade out class for filtering */
  .portfolio-card.fade-out {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }

  .card-img-wrap { position: relative; height: 220px; overflow: hidden; background: var(--bg-card); }

  .img-shimmer {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(110deg, var(--border-color) 8%, var(--bg-secondary) 18%, var(--border-color) 33%);
    background-size: 200% 100%;
    animation: shimmerLoad 1.5s linear infinite;
    transition: opacity 0.4s ease;
  }
  @keyframes shimmerLoad { to { background-position: -200% 0; } }

  .card-img {
    width: 100%; height: 100%; object-fit: cover;
    position: relative; z-index: 2; display: block;
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .portfolio-card:hover .card-img { transform: scale(1.07); }

  .card-glass-overlay {
    position: absolute; inset: 0; z-index: 3;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;
    background: rgba(0,196,204,0.55);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    opacity: 0; transition: opacity 0.4s ease;
  }
  .portfolio-card:hover .card-glass-overlay { opacity: 1; }

  .card-overlay-label {
    font-size: 0.875rem; font-weight: 700; color: white;
    letter-spacing: 0.05em; text-transform: uppercase;
    transform: translateY(8px);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .card-overlay-icon {
    color: rgba(255,255,255,0.8); font-size: 1.1rem;
    transform: translateY(8px);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1) 0.04s;
  }
  .portfolio-card:hover .card-overlay-label,
  .portfolio-card:hover .card-overlay-icon { transform: translateY(0); }

  .card-cat-pill {
    position: absolute; top: 0.75rem; left: 0.75rem; z-index: 4;
    padding: 0.25rem 0.75rem; border-radius: 9999px;
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    background: rgba(255,255,255,0.72); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.5); color: #00A3AA;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    white-space: nowrap; max-width: calc(100% - 1.5rem);
    overflow: hidden; text-overflow: ellipsis;
  }
  html.dark .card-cat-pill {
    background: rgba(15,23,42,0.75); border-color: rgba(0,196,204,0.2); color: #00C4CC;
  }

  .card-body { padding: 1.25rem 1.375rem 1.375rem; }
  .card-title { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; line-height: 1.3; }
  .card-desc {
    font-size: 0.84rem; line-height: 1.65; color: var(--text-muted); margin: 0 0 1rem;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-cta {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.07em; color: #00C4CC; text-transform: uppercase;
  }
  .card-cta-arrow { transition: transform 0.3s ease; font-size: 0.65rem; }
  .portfolio-card:hover .card-cta-arrow { transform: translateX(4px); }
</style>

<script>
  function initPortfolio() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-pill');
    const grid = document.getElementById('portfolio-grid') as HTMLElement | null;
    const indicator = document.getElementById('tab-indicator') as HTMLElement | null;
    const tabBar = document.getElementById('work-tabs') as HTMLElement | null;
    
    if (!grid) return;
    
    // Store original cards in memory to pristine DOM order
    const allCards = Array.from(grid.querySelectorAll('.portfolio-card')) as HTMLElement[];

    // ── Shimmer removal ──
    allCards.forEach(card => {
      const img = card.querySelector('img') as HTMLImageElement | null;
      const shimmer = card.querySelector('.img-shimmer') as HTMLElement | null;
      if (!img || !shimmer) return;
      const hide = () => { shimmer.style.opacity = '0'; };
      if (img.complete) hide(); else img.addEventListener('load', hide);
    });

    // ── Move indicator to a tab ──
    const moveIndicator = (tab: HTMLButtonElement) => {
      if (!indicator || !tabBar) return;
      const barRect = tabBar.getBoundingClientRect();
      const tabRect = tab.getBoundingClientRect();
      indicator.style.left  = `${tabRect.left - barRect.left + tabBar.scrollLeft}px`;
      indicator.style.width = `${tabRect.width}px`;
      indicator.style.opacity = '1';
    };

    // ── Filter cards by re-appending to DOM ──
    const filterCards = (selected: string) => {
      // 1. Fade out current cards
      const currentCards = Array.from(grid.children) as HTMLElement[];
      currentCards.forEach(c => c.classList.add('fade-out'));
      
      // 2. Wait for fade out, then swap DOM elements
      setTimeout(() => {
        grid.innerHTML = ''; // Clear grid
        
        // Append matching cards back
        allCards.forEach(card => {
          const matches = selected === 'All' || card.dataset.category === selected;
          if (matches) {
            // Reset state
            card.classList.remove('fade-out');
            
            // Retrigger entrance animation trick
            card.style.animation = 'none';
            card.offsetHeight; // trigger reflow
            card.style.animation = '';
            
            grid.appendChild(card);
          }
        });
      }, 300); // 300ms matches transform transition
    };

    // ── Tab click handler ──
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        if (tab.classList.contains('tab-pill-active')) return; // ignore clicks on active tab
        
        tabs.forEach(t => {
          t.classList.remove('tab-pill-active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('tab-pill-active');
        tab.setAttribute('aria-selected', 'true');
        moveIndicator(tab);
        filterCards(tab.dataset.category || 'All');
      });
    });

    // Init indicator on load
    requestAnimationFrame(() => requestAnimationFrame(() => {
      const active = document.querySelector<HTMLButtonElement>('.tab-pill-active');
      if (active) moveIndicator(active);
    }));
  }

  initPortfolio();
  document.addEventListener('astro:after-swap', initPortfolio);
</script>

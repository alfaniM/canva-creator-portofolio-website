---
/**
 * OptimizedImage — Smart image component with blur-up LQIP.
 *
 * Strategy:
 *  • Remote URLs   → Astro's <Image /> → Sharp converts to WebP
 *  • Local/CMS     → plain <img> with all perf attributes
 *  • All images    → CSS blur-up placeholder that fades out on load
 *
 * Result: ~30-80% smaller files, zero layout shift, perceived-instant loads.
 */
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  quality?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
  inferSize?: boolean;
}

const {
  src,
  alt,
  class: className = '',
  width = 1200,
  height = 900,
  quality = 82,
  loading = 'lazy',
  fetchpriority = 'auto',
  sizes,
  inferSize = false,
} = Astro.props;

const isRemote = src.startsWith('http://') || src.startsWith('https://') || src.startsWith('//');
---

<div class="optimized-img-wrap" style={`aspect-ratio: ${width}/${height};`}>
  {isRemote ? (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      inferSize={inferSize || undefined}
      quality={quality}
      format="webp"
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      sizes={sizes}
      class={`optimized-img ${className}`}
      style="object-fit: cover; display: block;"
      onload="this.parentElement.classList.add('img-loaded')"
    />
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      sizes={sizes}
      class={`optimized-img ${className}`}
      style="object-fit: cover; display: block;"
      onload="this.parentElement.classList.add('img-loaded')"
    />
  )}
</div>

<style>
  .optimized-img-wrap {
    position: relative;
    overflow: hidden;
    background: var(--bg-card, #f3f4f6);
  }

  /* Blur-up placeholder shimmer */
  .optimized-img-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(110deg, var(--border-color, #e5e7eb) 8%, var(--bg-secondary, #f9fafb) 18%, var(--border-color, #e5e7eb) 33%);
    background-size: 200% 100%;
    animation: shimmerBlur 1.5s linear infinite;
    transition: opacity 0.5s ease;
  }

  /* Fade out the placeholder when image loads */
  .optimized-img-wrap.img-loaded::before {
    opacity: 0;
    pointer-events: none;
  }

  .optimized-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .optimized-img-wrap.img-loaded .optimized-img {
    opacity: 1;
  }

  @keyframes shimmerBlur {
    to { background-position: -200% 0; }
  }
</style>

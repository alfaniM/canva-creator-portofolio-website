---
import siteData from '../data/site.json';
const { testimonials } = siteData;
---

<section id="testimonials" class="py-24 relative overflow-hidden" style="background: var(--bg-primary)">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="section-eyebrow">— What Clients Say</p>
      <h2 class="section-heading">
        Client <span class="text-gradient">Testimonials</span>
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="testimonials-grid">
      {testimonials.map((t, idx) => (
        <div class="testimonial-card reveal" style={`animation-delay: ${idx * 0.1}s`}>
          <!-- Stars -->
          <div class="stars-row" aria-label={`${t.rating} out of 5 stars`}>
            {Array.from({ length: t.rating }).map(() => (
              <i class="fa-solid fa-star"></i>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="testimonial-quote">
            <i class="fa-solid fa-quote-left quote-icon" aria-hidden="true"></i>
            {t.quote}
          </blockquote>

          <!-- Author -->
          <div class="testimonial-author">
            <div class="author-avatar">
              {t.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
            </div>
            <div>
              <p class="author-name">{t.name}</p>
              <p class="author-role">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #00C4CC;
    margin-bottom: 0.5rem;
    display: block;
  }

  .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--text-primary);
  }

  .text-gradient {
    background: linear-gradient(135deg, #00C4CC, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Grid ── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 1.5rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.35s ease,
                border-color 0.25s;
  }
  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px var(--shadow-hover);
    border-color: rgba(0,196,204,0.25);
  }

  .stars-row { display: flex; gap: 0.2rem; }
  .stars-row i { color: #F59E0B; font-size: 0.85rem; }

  .testimonial-quote {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-secondary);
    flex: 1;
    position: relative;
  }

  .quote-icon {
    color: rgba(0,196,204,0.25);
    font-size: 1.5rem;
    margin-right: 0.35rem;
    vertical-align: -0.1em;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--border-color);
  }

  .author-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #00C4CC, #a855f7);
    color: white;
    font-size: 0.85rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .author-role {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
</style>
